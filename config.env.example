# API KEYS CONFIGURATION TEMPLATE
# Copy this file to `config.env` and fill real values locally.

# UPSTOX
UPSTOX_API_KEY=YOUR_UPSTOX_API_KEY
UPSTOX_API_SECRET=YOUR_UPSTOX_API_SECRET
UPSTOX_REDIRECT_URI=http://127.0.0.1:5000/callback

# AI PROVIDERS
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
PERPLEXITY_API_KEY=YOUR_PERPLEXITY_API_KEY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# AI COUNCIL (OPTIONAL)
AI_COUNCIL_ENABLED=0
AI_COUNCIL_CYCLE_SECONDS=300
AI_COUNCIL_MIN_TELEGRAM_PRIORITY=high
AI_COUNCIL_OPENAI_MODEL=gpt-4o-mini
AI_COUNCIL_COST_MODE=mostly_free
AI_COUNCIL_MAX_DAILY_BUDGET_USD=8
AI_COUNCIL_MIN_CITATIONS=1
AI_COUNCIL_MAX_SOURCE_AGE_SEC=7200
AI_COUNCIL_HARD_VETO=1

# TELEGRAM (OPTIONAL)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ANGEL ONE
ANGEL_CLIENT_ID=YOUR_ANGEL_CLIENT_ID
ANGEL_PASSWORD=YOUR_ANGEL_PASSWORD
ANGEL_TOTP_SECRET=YOUR_ANGEL_TOTP_SECRET
ANGEL_HISTORICAL_API_KEY=YOUR_ANGEL_HISTORICAL_API_KEY
ANGEL_TRADING_API_KEY=YOUR_ANGEL_TRADING_API_KEY
ANGEL_MARKET_FEED_API_KEY=YOUR_ANGEL_MARKET_FEED_API_KEY
ANGEL_PUBLISHER_API_KEY=YOUR_ANGEL_PUBLISHER_API_KEY

# MARKET PARAMETERS
RISK_FREE_RATE=0.06695
DIVIDEND_YIELD=0.013
